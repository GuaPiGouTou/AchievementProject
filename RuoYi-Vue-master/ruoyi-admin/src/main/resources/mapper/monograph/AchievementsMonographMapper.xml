        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
    </resultMap>

    <sql id="selectAchievementsMonographVo">
        select monograph_id, user_id, dept_id, monograph_title, author_role, press_name, isbn_number, publish_date, monograph_type, edition, word_count, page_count, language, subject_category, is_included, included_database, award_situation, co_authors, international_standard_book_number, china_classification_number, audit_status, created_at, updated_at from achievements_monograph
    </sql>

    <select id="selectAchievementsMonographList" parameterType="AchievementsMonograph" resultMap="AchievementsMonographResult">
        <include refid="selectAchievementsMonographVo"/>
        <where>  
            <if test="userId != null"> and user_id = #{userId}</if>
            <if test="params.scopedDeptIds != null and params.scopedDeptIds.size() &gt; 0">
                and dept_id in
                <foreach item="scopedDeptId" collection="params.scopedDeptIds" open="(" separator="," close=")">
                    #{scopedDeptId}
                </foreach>
            </if>
            <if test="deptId != null"> and dept_id = #{deptId}</if>
            <if test="monographTitle != null  and monographTitle != ''"> and monograph_title like concat('%', #{monographTitle}, '%')</if>
            <if test="authorRole != null  and authorRole != ''"> and author_role = #{authorRole}</if>
            <if test="publishDate != null "> and publish_date = #{publishDate}</if>
            <if test="params.beginPublishDate != null and params.beginPublishDate != ''"> and publish_date &gt;= #{params.beginPublishDate}</if>
            <if test="params.endPublishDate != null and params.endPublishDate != ''"> and publish_date &lt;= #{params.endPublishDate}</if>
            <if test="monographType != null  and monographType != ''"> and monograph_type = #{monographType}</if>
            <if test="language != null  and language != ''"> and language = #{language}</if>
            <if test="isIncluded != null"> and is_included = #{isIncluded}</if>
            <if test="subjectCategory != null  and subjectCategory != ''"> and subject_category like concat('%', #{subjectCategory}, '%')</if>
            <if test="auditStatus != null  and auditStatus != ''"> and audit_status = #{auditStatus}</if>
            <if test="params.beginCreatedAt != null and params.beginCreatedAt != ''"> and created_at &gt;= #{params.beginCreatedAt}</if>
            <if test="params.endCreatedAt != null and params.endCreatedAt != ''"> and created_at &lt;= #{params.endCreatedAt}</if>
            <if test="params.beginUpdatedAt != null and params.beginUpdatedAt != ''"> and updated_at &gt;= #{params.beginUpdatedAt}</if>
            <if test="params.endUpdatedAt != null and params.endUpdatedAt != ''"> and updated_at &lt;= #{params.endUpdatedAt}</if>
        </where>
    </select>
    
    <select id="selectAchievementsMonographByMonographId" parameterType="Long" resultMap="AchievementsMonographResult">
        <include refid="selectAchievementsMonographVo"/>
        where monograph_id = #{monographId}
    </select>

