            <if test="monographType != null and monographType != ''">monograph_type,</if>
            <if test="edition != null">edition,</if>
            <if test="wordCount != null">word_count,</if>
            <if test="pageCount != null">page_count,</if>
            <if test="language != null">language,</if>
            <if test="subjectCategory != null">subject_category,</if>
            <if test="isIncluded != null">is_included,</if>
            <if test="includedDatabase != null and includedDatabase != ''">included_database,</if>
            <if test="awardSituation != null">award_situation,</if>
            <if test="coAuthors != null">co_authors,</if>
            <if test="internationalStandardBookNumber != null">international_standard_book_number,</if>
            <if test="chinaClassificationNumber != null">china_classification_number,</if>
            <if test="auditStatus != null">audit_status,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="monographTitle != null and monographTitle != ''">#{monographTitle},</if>
            <if test="authorRole != null and authorRole != ''">#{authorRole},</if>
            <if test="pressName != null and pressName != ''">#{pressName},</if>
            <if test="isbnNumber != null and isbnNumber != ''">#{isbnNumber},</if>
            <if test="publishDate != null">#{publishDate},</if>
            <if test="monographType != null and monographType != ''">#{monographType},</if>
            <if test="edition != null">#{edition},</if>
