        delete from achievements_research where research_id = #{researchId}
    </delete>

    <delete id="deleteAchievementsResearchByResearchIds" parameterType="String">
        delete from achievements_research where research_id in 
        <foreach item="researchId" collection="array" open="(" separator="," close=")">
