    <sql id="selectAchievementsResearchVo">
        select research_id, user_id, dept_id, project_number, project_category, project_level, project_type, project_name, principal, participants, organizing_unit, total_funding, received_funding, funding_unit, start_date, end_date, actual_end_date, project_status, completion_status, research_field, audit_status, created_at, updated_at from achievements_research
    </sql>

    <select id="selectAchievementsResearchList" parameterType="AchievementsResearch" resultMap="AchievementsResearchResult">
        <include refid="selectAchievementsResearchVo"/>
        <where>  
            <if test="projectNumber != null  and projectNumber != ''"> and project_number = #{projectNumber}</if>
            <if test="projectName != null  and projectName != ''"> and project_name like concat('%', #{projectName}, '%')</if>
            <if test="principal != null  and principal != ''"> and principal = #{principal}</if>
            <if test="totalFunding != null "> and total_funding = #{totalFunding}</if>
            <if test="projectStatus != null  and projectStatus != ''"> and project_status = #{projectStatus}</if>
            <if test="auditStatus != null  and auditStatus != ''"> and audit_status = #{auditStatus}</if>
            <if test="createdAt != null "> and created_at = #{createdAt}</if>
            <if test="updatedAt != null "> and updated_at = #{updatedAt}</if>
        </where>
    </select>
    
    <select id="selectAchievementsResearchByResearchId" parameterType="Long" resultMap="AchievementsResearchResult">
        <include refid="selectAchievementsResearchVo"/>
        where research_id = #{researchId}
    </select>

